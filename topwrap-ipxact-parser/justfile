export PATH := x"$PATH:$HOME/.local/bin"

generateds_version := "2.44.3"
patches_dir := justfile_directory() / "patches"
ipxact_schema_repo := "https://github.com/edaa-org/IPXACT-Schema"
ipxact_schema_sha := "3c683290483598378435ff93d38c5354fb9e5514"

default:
	@just --list

[arg("docs",long,value="1")]
install-debian-deps docs="0":
    #!/usr/bin/env bash
    apt-get update -qq
    apt-get install -y --no-install-recommends \
        curl \
        git \
        python3-dev \
        python3-pip \
        python3-venv \
        make

    if [[ {{docs}} == "1" ]];then apt-get install -y texlive-full imagemagick make chromium; fi

    curl -LsSf https://astral.sh/uv/install.sh | sh

# Run the small parsing example
example:
    uv run examples/parse_example.py

# Regenerate the parser using generateDS and the IP-XACT schema
regenerate:
    rm -rf generateDS-{{generateds_version}} generateDS-{{generateds_version}}-py3-none-any.whl ipxact-schema .generate-venv
    pip download generateDS=={{generateds_version}} --no-deps -d .
    unzip -q generateDS-{{generateds_version}}-py3-none-any.whl -d generateDS-{{generateds_version}}
    cd generateDS-{{generateds_version}}/generateDS-{{generateds_version}}.data/scripts && \
        patch -p1 < {{patches_dir}}/0001-Add-no-pattern-validator-flag.patch
    uv venv --quiet .generate-venv
    uv pip install --quiet --python .generate-venv six lxml "requests>=2.21.0"
    mkdir ipxact-schema
    cd ipxact-schema && git init -q && git remote add origin {{ipxact_schema_repo}} && \
        git fetch --depth 1 origin {{ipxact_schema_sha}} && git checkout -q FETCH_HEAD
    patch -p1 -d ipxact-schema < {{patches_dir}}/0002-Change-complexContent-to-simpleContent-in-abstractio.patch
    patch -p1 -d ipxact-schema < {{patches_dir}}/0003-Change-how-the-access-element-is-referenced-in-memor.patch
    .generate-venv/bin/python3 generateDS-{{generateds_version}}/generateDS-{{generateds_version}}.data/scripts/generateDS.py \
        -f -o topwrap_ipxact_parser/__init__.py --no-pattern-validator \
        ipxact-schema/ieee-1685-2022/index.xsd
    rm -rf .generate-venv
    sed -i -E \
        -e 's/^# Generated .+ by generateDS\.py version/# Generated by generateDS.py version/' \
        -e '/^# Python [0-9]+\.[0-9]+\.[0-9]+ /d' \
        topwrap_ipxact_parser/__init__.py
    uvx ruff format topwrap_ipxact_parser/__init__.py

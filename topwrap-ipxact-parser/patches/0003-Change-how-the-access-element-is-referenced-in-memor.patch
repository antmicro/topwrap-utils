From bc4a94268e9a03225fd649d69cab3ff8a83155ad Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Wojciech=20Ko=C5=82odziej?=
 <wkolodziej@internships.antmicro.com>
Date: Thu, 2 Jul 2026 12:01:55 +0200
Subject: [PATCH] Change how the `access` element is referenced in memory map

GenerateDS don't support old convention. New convention was copied from
2014 version. In generated parsed by GenerateDS restriction don't work
and additional verification is needed after parsing.
---
 ieee-1685-2009/memoryMap.xsd | 13 +++++--------
 1 file changed, 5 insertions(+), 8 deletions(-)

diff --git a/ieee-1685-2009/memoryMap.xsd b/ieee-1685-2009/memoryMap.xsd
index 3d66ed3..27781a9 100644
--- a/ieee-1685-2009/memoryMap.xsd
+++ b/ieee-1685-2009/memoryMap.xsd
@@ -307,14 +307,11 @@
             <xs:documentation>Indicates whether the data is volatile.</xs:documentation>
         </xs:annotation>
     </xs:element>
-    <xs:element name="access">
-        <xs:annotation>
-            <xs:documentation>Indicates the accessibility of the data in the address bank, address block, register or field.  Possible values are 'read-write', 'read-only',  'write-only', 'writeOnce' and 'read-writeOnce'. If not specified the value is inherited from the containing object.</xs:documentation>
-        </xs:annotation>
-        <xs:simpleType>
-            <xs:restriction base="spirit:accessType"/>
-        </xs:simpleType>
-    </xs:element>
+		<xs:element name="access" type="spirit:accessType">
+			<xs:annotation>
+				<xs:documentation>Indicates the accessibility of the data in the address bank, address block, register or field.  Possible values are 'read-write', 'read-only',  'write-only', 'writeOnce' and 'read-writeOnce'. If not specified the value is inherited from the containing object.</xs:documentation>
+			</xs:annotation>
+		</xs:element>
     <xs:element name="addressBlock" type="spirit:addressBlockType">
         <xs:annotation>
             <xs:documentation>This is a single contiguous block of memory inside a memory map.</xs:documentation>
-- 
